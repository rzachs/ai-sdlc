{
  "name": "@ai-sdlc/reference",
  "version": "0.6.0",
  "description": "AI-SDLC Framework reference implementation",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/ai-sdlc-framework/ai-sdlc.git",
    "directory": "reference"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.map"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "generate-schemas": "tsx scripts/generate-schemas.ts && prettier --write src/core/generated-schemas.ts",
    "prebuild": "pnpm generate-schemas",
    "build": "tsc",
    "clean": "rm -rf dist *.tsbuildinfo",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "validate-schemas": "tsx src/core/validate-schemas.ts"
  },
  "dependencies": {
    "@linear/sdk": "^37.0.0",
    "@octokit/rest": "^22.0.1",
    "@opentelemetry/api": "^1.9.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
