#!/usr/bin/env bash
# Husky pre-push hook. Order matters:
#
#   1. Coverage gate — fails fast on under-tested code so we don't
#      sign an attestation for a build we'd reject anyway.
#      NOTE: pnpm test:coverage is known to show transient failures (up to 17
#      tests across 3 files) when multiple worktrees run pre-push hooks
#      concurrently and share /tmp space. If you see intermittent failures,
#      retry with AI_SDLC_SKIP_COVERAGE_GATE=1 git push once, then re-run
#      coverage in isolation. See docs/operations/merge-queue-rebase-recovery.md
#      "Coverage gate flake" section for the full retry recipe (AISDLC-357).
#   2. Squash stacked chore-sign commits (AISDLC-369) — when multiple
#      consecutive "chore: sign attestation" commits accumulate at HEAD
#      (from re-sign cycles), squashes them into one to keep history clean.
#      ORDER: MUST run BEFORE attestation-sign (item 4 below) so the
#      squashed HEAD is the one the attestation is signed against.
#      No-op when there is 0 or 1 chore-sign commit at HEAD.
#   3. DoR gate (AISDLC-370) — runs `cli-dor-check --task <path>` against any
#      `backlog/{tasks,completed}/*.md` files staged in this push, so DoR
#      violations (gate-2 markers, gate-3 unresolved references, gate-7
#      dependency phrases, upstream-OQ blocks) fail locally before CI cycles.
#      Runs before the orchestrator so DoR violations block the push without
#      spending time on mechanical fixups. Skip: AI_SDLC_SKIP_DOR_GATE=1.
#   4. Mechanical fixups orchestrator (AISDLC-386) — runs all three mechanical
#      fixup sub-hooks in dependency order in a single pass:
#        task-move (AISDLC-220) → mcp-bundle-sync (AISDLC-357) → attestation-sign (AISDLC-133)
#      If any fixup ran, exits 1 ONCE with a consolidated "re-run git push"
#      message instead of each sub-hook exiting 1 separately (collapses the
#      worst-case 4-push chain into 2). ORDER IS LOAD-BEARING: task-move
#      MUST run before attestation-sign (attestation's contentHashV4 binds
#      {path, headBlobSha}; if move happens after sign the envelope references
#      the old path → verify-attestation rejects).
#   5-7. Individual sub-hook invocations (task-moved, mcp-bundle-sync,
#      attestation-sign) remain below as defense-in-depth: on the re-push
#      after the orchestrator exits 1, the orchestrator sees no fixups needed
#      and exits 0. Each sub-hook's idempotency check then confirms clean state.
#      If the orchestrator is bypassed (AI_SDLC_BYPASS_ALL_GATES), the
#      individual hooks below also skip (they check the same bypass var).
#
# Skip individual gates with their respective env vars
# (AI_SDLC_SKIP_COVERAGE_GATE=1, AI_SDLC_SKIP_TASK_MOVE=1,
# AI_SDLC_SKIP_MCP_BUNDLE_SYNC=1, AI_SDLC_SKIP_SQUASH_CHORES=1,
# AI_SDLC_SKIP_DOR_GATE=1, AI_SDLC_SKIP_ATTESTATION_SIGN=1)
# or skip all pre-push hooks via `git push --no-verify` (use sparingly —
# these gates exist because the things they guard have failed silently in
# the past).

set -euo pipefail

# Read git's pre-push stdin once so multiple gates can consume the range info.
# (AISDLC-370: DoR gate uses the push range to walk touched task files.)
PUSH_STDIN="$(cat || true)"

./scripts/check-coverage.sh
if [ "${AI_SDLC_SKIP_SQUASH_CHORES:-}" != "1" ]; then
  ./scripts/squash-attestation-chores.sh
fi
printf '%s\n' "$PUSH_STDIN" | ./scripts/check-dor-gate.sh
# AISDLC-386: orchestrator handles all mechanical fixups (task-move →
# mcp-bundle-sync → attestation-sign) in a single pass and exits 1 ONCE if
# any work was done. This collapses the worst-case 4-push chain into 2.
# The individual hook invocations below act as defense-in-depth: on the
# re-push after the orchestrator exits 1, the orchestrator sees no fixups
# needed and exits 0, then each sub-hook's own idempotency check confirms
# the state is clean. If the orchestrator is bypassed (AI_SDLC_BYPASS_ALL_GATES)
# the individual hooks below also skip (they check the same bypass var).
printf '%s\n' "$PUSH_STDIN" | ./scripts/pre-push-fixups.sh
./scripts/check-task-moved.sh
./scripts/check-mcp-bundle-sync.sh
./scripts/check-attestation-sign.sh
