{
  "name": "@ai-sdlc/dogfood",
  "version": "0.1.0",
  "private": true,
  "description": "AI-SDLC dogfood pipeline — uses the framework to govern its own repo",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./runner": {
      "types": "./dist/runner/index.d.ts",
      "import": "./dist/runner/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist *.tsbuildinfo",
    "test": "vitest run",
    "test:watch": "vitest",
    "execute": "tsx src/cli.ts",
    "fix-ci": "tsx src/cli-fix-ci.ts",
    "watch": "tsx src/cli-watch.ts"
  },
  "dependencies": {
    "@ai-sdlc/orchestrator": "workspace:*",
    "@ai-sdlc/reference": "workspace:*",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
